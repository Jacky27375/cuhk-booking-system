<div id="<%= dom_id booking %>">
  <div>
    <strong>Venue:</strong>
    <%= booking.venue.name %>
  </div>

  <div>
    <strong>User:</strong>
    <%= booking.user.email %>
  </div>

  <div>
    <strong>Start time:</strong>
    <%= booking.start_time %>
  </div>

  <div>
    <strong>End time:</strong>
    <%= booking.end_time %>
  </div>

</div>
