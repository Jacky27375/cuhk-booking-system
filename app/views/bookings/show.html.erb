<%= render @booking %>

<div>
  <% if respond_to?(:current_user) && current_user&.society_member? %>
    <%= link_to "Edit this booking", edit_booking_path(@booking) %> |
    <%= link_to "My Bookings", my_bookings_path %>

    <%= button_to "Destroy this booking", @booking, method: :delete %>
  <% end %>
</div>
