<h1>My Bookings</h1>

<div data-controller="booking-status">
  <% if @bookings.empty? %>
    <p>No bookings found.</p>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>Resource</th>
          <th>Date</th>
          <th>Details</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @bookings.each do |booking| %>
          <tr id="booking_<%= booking.id %>">
            <% if booking.venue.present? %>
              <td><%= booking.venue.name %></td>
              <td><%= booking.start_time.to_date %></td>
              <td><%= booking.start_time.strftime("%H:%M") %> - <%= booking.end_time.strftime("%H:%M") %></td>
            <% elsif booking.equipment.present? %>
              <td><%= booking.equipment.name %></td>
              <td><%= booking.start_date %> to <%= booking.end_date %></td>
              <td>Qty: <%= booking.quantity %></td>
            <% end %>
            <td data-booking-id="<%= booking.id %>" data-status="<%= booking.status %>"><%= booking.status.titleize %></td>
            <td>
              <% if booking.returnable? %>
                <%= button_to "Mark as Returned", mark_returned_booking_path(booking), method: :patch, data: { turbo: false } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>

<%= link_to "Back to Dashboard", dashboard_path %>
