<% content_for(:title) { "Analytics Dashboard — CUHK Booking System" } %>

<h1>Analytics Dashboard</h1>

<p><%= link_to "← Back to Dashboard", dashboard_path %></p>

<%# ===== Date Range Filter ===== %>
<div class="analytics-filter">
  <%= form_tag analytics_path, method: :get do %>
    <label>From:
      <%= date_field_tag :start_date, @start_date, style: "padding: 0.3rem;" %>
    </label>
    <label>To:
      <%= date_field_tag :end_date, @end_date, style: "padding: 0.3rem;" %>
    </label>
    <%= submit_tag "Filter", style: "padding: 0.4rem 1.2rem; background: #4e73df; color: #fff; border: none; border-radius: 4px; cursor: pointer;" %>
    <%= link_to "Reset", analytics_path, style: "color: #4e73df;" %>
  <% end %>
  <small style="color: #666;">Showing data from <strong><%= @start_date %></strong> to <strong><%= @end_date %></strong></small>
</div>

<%# ===== Summary Stats Cards ===== %>
<div class="analytics-cards">
  <div class="analytics-card" style="background: #4e73df;">
    <div class="analytics-card-value"><%= @total_bookings %></div>
    <div>Total Bookings</div>
  </div>
  <div class="analytics-card" style="background: #f6c23e;">
    <div class="analytics-card-value"><%= @pending_count %></div>
    <div>Pending</div>
  </div>
  <div class="analytics-card" style="background: #1cc88a;">
    <div class="analytics-card-value"><%= @approved_count %></div>
    <div>Approved</div>
  </div>
  <div class="analytics-card" style="background: #e74a3b;">
    <div class="analytics-card-value"><%= @rejected_count %></div>
    <div>Rejected</div>
  </div>
  <div class="analytics-card" style="background: #36b9cc;">
    <div class="analytics-card-value"><%= @venues_count %></div>
    <div>Venues</div>
  </div>
  <div class="analytics-card" style="background: #858796;">
    <div class="analytics-card-value"><%= @equipment_count %></div>
    <div>Equipment</div>
  </div>
</div>

<div class="analytics-grid">

  <%# Venue Booking Counts - Bar Chart %>
  <div class="analytics-panel">
    <h2>Bookings per Venue</h2>
    <% if @venue_booking_counts.any? %>
      <div data-controller="chart"
           data-chart-type-value="bar"
           data-chart-labels-value="<%= @venue_booking_counts.keys.to_json %>"
           data-chart-data-value="<%= @venue_booking_counts.values.to_json %>"
           data-chart-label-value="Bookings">
        <canvas data-chart-target="canvas"></canvas>
      </div>
    <% else %>
      <div class="analytics-empty-state"><p>No venue bookings yet.</p></div>
    <% end %>
  </div>

  <%# Venue Duration (Hours) - Horizontal Bar Chart %>
  <div class="analytics-panel">
    <h2>Total Booked Hours per Venue</h2>
    <% if @venue_duration_hours.any? %>
      <div data-controller="chart"
           data-chart-type-value="bar"
           data-chart-labels-value="<%= @venue_duration_hours.keys.to_json %>"
           data-chart-data-value="<%= @venue_duration_hours.values.map { |v| v.round(1) }.to_json %>"
           data-chart-label-value="Hours"
           data-chart-suffix-value="h"
           data-chart-colors-value='["#6f42c1"]'>
        <canvas data-chart-target="canvas"></canvas>
      </div>
    <% else %>
      <div class="analytics-empty-state"><p>No venue booking duration data yet.</p></div>
    <% end %>
  </div>

  <%# Venue Occupancy Rate - Bar Chart %>
  <div class="analytics-panel">
    <h2>Venue Occupancy Rate</h2>
    <% if @venue_occupancy_pct.any? %>
      <div data-controller="chart"
           data-chart-type-value="bar"
           data-chart-labels-value="<%= @venue_occupancy_pct.keys.to_json %>"
           data-chart-data-value="<%= @venue_occupancy_pct.values.to_json %>"
           data-chart-label-value="Occupancy"
           data-chart-suffix-value="%"
           data-chart-step-size-value="10"
           data-chart-colors-value='["#e74a3b"]'>
        <canvas data-chart-target="canvas"></canvas>
      </div>
    <% else %>
      <div class="analytics-empty-state"><p>No occupancy data yet.</p></div>
    <% end %>
  </div>

  <%# Booking Status Distribution - Doughnut Chart %>
  <div class="analytics-panel">
    <h2>Booking Status Distribution</h2>
    <% if @status_counts.any? %>
      <div data-controller="chart"
           data-chart-type-value="doughnut"
           data-chart-labels-value="<%= @status_counts.keys.to_json %>"
           data-chart-data-value="<%= @status_counts.values.to_json %>"
           data-chart-label-value="Status"
           data-chart-colors-value='["#f6c23e","#1cc88a","#e74a3b","#36b9cc","#858796"]'>
        <canvas data-chart-target="canvas"></canvas>
      </div>
    <% else %>
      <div class="analytics-empty-state"><p>No bookings yet.</p></div>
    <% end %>
  </div>

  <%# Daily Bookings Trend - Line Chart %>
  <div class="analytics-panel">
    <h2>Daily Bookings Trend</h2>
    <% if @daily_bookings.any? %>
      <div data-controller="chart"
           data-chart-type-value="line"
           data-chart-labels-value="<%= @daily_bookings.keys.map(&:to_s).to_json %>"
           data-chart-data-value="<%= @daily_bookings.values.to_json %>"
           data-chart-label-value="Bookings"
           data-chart-colors-value='["#4e73df"]'>
        <canvas data-chart-target="canvas"></canvas>
      </div>
    <% else %>
      <div class="analytics-empty-state"><p>No bookings in the selected period.</p></div>
    <% end %>
  </div>

  <%# Peak Hours - Bar Chart %>
  <div class="analytics-panel">
    <h2>Peak Booking Hours</h2>
    <% if @peak_hours.any? %>
      <div data-controller="chart"
           data-chart-type-value="bar"
           data-chart-labels-value="<%= @peak_hours.keys.map { |h| format('%02d:00', h) }.to_json %>"
           data-chart-data-value="<%= @peak_hours.values.to_json %>"
           data-chart-label-value="Bookings"
           data-chart-colors-value='["#1cc88a"]'>
        <canvas data-chart-target="canvas"></canvas>
      </div>
    <% else %>
      <div class="analytics-empty-state"><p>No venue bookings with time data.</p></div>
    <% end %>
  </div>

  <%# Weekly Bookings Trend - Bar Chart %>
  <div class="analytics-panel">
    <h2>Weekly Booking Trend</h2>
    <% if @weekly_bookings.any? %>
      <div data-controller="chart"
           data-chart-type-value="bar"
           data-chart-labels-value="<%= @weekly_bookings.keys.map { |w| "Week #{w}" }.to_json %>"
           data-chart-data-value="<%= @weekly_bookings.values.to_json %>"
           data-chart-label-value="Bookings"
           data-chart-colors-value='["#fd7e14"]'>
        <canvas data-chart-target="canvas"></canvas>
      </div>
    <% else %>
      <div class="analytics-empty-state"><p>No weekly data available.</p></div>
    <% end %>
  </div>

  <%# Day-of-Week Distribution - Bar Chart %>
  <div class="analytics-panel">
    <h2>Bookings by Day of Week</h2>
    <% if @day_of_week.values.sum > 0 %>
      <div data-controller="chart"
           data-chart-type-value="bar"
           data-chart-labels-value="<%= @day_of_week.keys.to_json %>"
           data-chart-data-value="<%= @day_of_week.values.to_json %>"
           data-chart-label-value="Bookings"
           data-chart-colors-value='["#20c997"]'>
        <canvas data-chart-target="canvas"></canvas>
      </div>
    <% else %>
      <div class="analytics-empty-state"><p>No day-of-week data available.</p></div>
    <% end %>
  </div>

  <%# Equipment Borrow Counts - Bar Chart %>
  <div class="analytics-panel">
    <h2>Equipment Borrow Count</h2>
    <% if @equipment_borrow_counts.any? %>
      <div data-controller="chart"
           data-chart-type-value="bar"
           data-chart-labels-value="<%= @equipment_borrow_counts.keys.to_json %>"
           data-chart-data-value="<%= @equipment_borrow_counts.values.to_json %>"
           data-chart-label-value="Times Borrowed"
           data-chart-colors-value='["#6610f2"]'>
        <canvas data-chart-target="canvas"></canvas>
      </div>
    <% else %>
      <div class="analytics-empty-state"><p>No equipment borrowing data yet.</p></div>
    <% end %>
  </div>

  <%# Equipment Quantity Borrowed - Bar Chart %>
  <div class="analytics-panel">
    <h2>Total Units Borrowed per Equipment</h2>
    <% if @equipment_quantity_borrowed.any? %>
      <div data-controller="chart"
           data-chart-type-value="bar"
           data-chart-labels-value="<%= @equipment_quantity_borrowed.keys.to_json %>"
           data-chart-data-value="<%= @equipment_quantity_borrowed.values.to_json %>"
           data-chart-label-value="Units"
           data-chart-colors-value='["#e83e8c"]'>
        <canvas data-chart-target="canvas"></canvas>
      </div>
    <% else %>
      <div class="analytics-empty-state"><p>No equipment quantity data yet.</p></div>
    <% end %>
  </div>

  <%# Equipment Booking Status - Doughnut Chart %>
  <div class="analytics-panel">
    <h2>Equipment Booking Status</h2>
    <% if @equipment_status_counts.any? %>
      <div data-controller="chart"
           data-chart-type-value="doughnut"
           data-chart-labels-value="<%= @equipment_status_counts.keys.to_json %>"
           data-chart-data-value="<%= @equipment_status_counts.values.to_json %>"
           data-chart-label-value="Status"
           data-chart-colors-value='["#f6c23e","#1cc88a","#e74a3b","#36b9cc","#858796"]'>
        <canvas data-chart-target="canvas"></canvas>
      </div>
    <% else %>
      <div class="analytics-empty-state"><p>No equipment booking data yet.</p></div>
    <% end %>
  </div>

</div>

<%# Peak Hours by Venue Heatmap Table %>
<% if @heatmap_venues.any? %>
<div class="analytics-heatmap">
  <h2>Peak Hours by Venue</h2>
  <table>
    <thead>
      <tr>
        <th>Venue</th>
        <% @heatmap_hours.each do |h| %>
          <th><%= format('%02d:00', h) %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% max_val = @heatmap_data.flatten.max || 1 %>
      <% @heatmap_venues.each_with_index do |venue, i| %>
        <tr>
          <td style="font-weight: bold; text-align: left; white-space: nowrap;"><%= venue %></td>
          <% @heatmap_data[i].each do |count| %>
            <% intensity = max_val > 0 ? (count.to_f / max_val) : 0 %>
            <td style="background: rgba(78,115,223,<%= (intensity * 0.8 + 0.05).round(2) %>); color: <%= intensity > 0.5 ? '#fff' : '#333' %>;"><%= count %></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>
