<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <h1>CUHK Booking System</h1>
      <p>Sign in to manage your bookings</p>
    </div>

    <% if flash[:alert] %>
      <div class="alert"><%= flash[:alert] %></div>
    <% end %>

    <%= form_with url: login_path, method: :post, data: { turbo: false } do |f| %>
      <div class="form-group">
        <%= f.label :email, "Email" %>
        <%= f.email_field :email, required: true, autofocus: true, placeholder: "you@link.cuhk.edu.hk" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password, required: true, placeholder: "Enter your password" %>
      </div>

      <div>
        <%= f.submit "Sign In", class: "btn-primary" %>
      </div>
    <% end %>

    <div class="auth-footer">
      Don't have an account? <%= link_to "Create one", signup_path %>
    </div>
  </div>
</div>
