<% content_for :title, "New Venue Request" %>
<% content_for(:page_title, "New Venue Request") %>

<div class="card">
  <div class="card-body">
    <p class="text-muted mb-2">Requesting a new venue for <strong><%= current_user.tenant.name %></strong></p>

    <% if @venue_request.errors.any? %>
      <div class="alert">
        <ul style="margin:0; padding-left:1.2rem;">
          <% @venue_request.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @venue_request, url: venue_requests_path, method: :post do |f| %>
      <div class="form-group">
        <%= f.label :venue_name, "Venue Name" %>
        <%= f.text_field :venue_name, required: true, autofocus: true, placeholder: "e.g. Room 201 Student Centre" %>
      </div>

      <div class="form-group">
        <%= f.label :description %>
        <%= f.text_area :description, placeholder: "Description of the venue and its intended use", rows: 4 %>
      </div>

      <div class="btn-group">
        <%= f.submit "Submit Request", class: "btn-primary" %>
        <%= link_to "Cancel", venue_requests_path, class: "btn btn-secondary btn-sm" %>
      </div>
    <% end %>
  </div>
</div>
