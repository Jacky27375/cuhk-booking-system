<% content_for :title, "Venue Requests" %>
<% content_for(:page_title, "Venue Requests") %>

<div class="page-actions">
  <p class="text-muted text-sm">
    <% if current_user.admin? %>
      Showing <%= @venue_requests.size %> of <%= @status_counts["all"] %> request(s)
    <% else %>
      <%= @venue_requests.size %> request(s)
    <% end %>
  </p>
  <span class="spacer"></span>
  <% if current_user.staff? %>
    <%= link_to "New Venue Request", new_venue_request_path, class: "btn btn-primary btn-sm" %>
  <% end %>
</div>

<% if current_user.admin? %>
  <div class="btn-group mb-2">
    <% [["Pending", "pending"], ["Approved", "approved"], ["Rejected", "rejected"], ["All", "all"]].each do |label, key| %>
      <%= link_to "#{label} (#{@status_counts[key]})",
                  venue_requests_path(status: key),
                  class: "btn btn-sm #{key == @status_filter ? 'btn-primary' : 'btn-secondary'}" %>
    <% end %>
  </div>
<% end %>

<% if @venue_requests.any? %>
  <div class="card">
    <table class="resource-grid-table" style="margin:0; border:none; box-shadow:none;">
      <thead>
        <tr>
          <th>Venue Name</th>
          <th>Description</th>
          <% if current_user.admin? %><th>Requested By</th><% end %>
          <th>College</th>
          <th>Status</th>
          <% if current_user.admin? %><th>Requested At</th><% end %>
          <% if current_user.admin? %><th>Reviewed By</th><% end %>
          <% if current_user.admin? %><th>Reviewed At</th><% end %>
          <% if current_user.admin? %><th>Rejection Reason</th><% end %>
          <% if current_user.admin? %><th>Actions</th><% end %>
        </tr>
      </thead>
      <tbody>
        <% @venue_requests.each do |request| %>
          <tr<%= ' style="background-color: rgba(255, 243, 205, 0.45);"' if request.pending? %>>
            <td><strong><%= request.venue_name %></strong></td>
            <td class="text-muted"><%= request.description %></td>
            <% if current_user.admin? %><td><%= request.requester.email %></td><% end %>
            <td><span class="badge badge-role"><%= request.tenant.name %></span></td>
            <td>
              <%= status_badge(request.status) %>
              <% if request.pending? %>
                <div class="text-muted text-sm">Needs review</div>
              <% end %>
            </td>
            <% if current_user.admin? %><td class="text-muted"><%= request.created_at.strftime("%Y-%m-%d %H:%M") %></td><% end %>
            <% if current_user.admin? %><td><%= request.reviewed_by&.email || "-" %></td><% end %>
            <% if current_user.admin? %><td class="text-muted"><%= request.reviewed_at&.strftime("%Y-%m-%d %H:%M") || "-" %></td><% end %>
            <% if current_user.admin? %><td class="text-muted"><%= request.rejection_reason.presence || "-" %></td><% end %>
            <% if current_user.admin? %>
              <td>
                <% if request.pending? %>
                  <div class="btn-group">
                    <%= button_to "Approve", approve_venue_request_path(request), method: :patch, class: "btn btn-primary btn-sm", data: { turbo_confirm: "Approve this venue request?" } %>
                    <%= form_with url: reject_venue_request_path(request), method: :patch, local: true do |f| %>
                      <%= f.label :rejection_reason, "Rejection reason" %>
                      <%= f.text_field :rejection_reason, required: true, placeholder: "Reason for rejection" %>
                      <%= f.submit "Reject", class: "btn btn-danger btn-sm", data: { turbo_confirm: "Reject this venue request?" } %>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-muted text-sm">Reviewed</span>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="empty-state">
    <h3>No venue requests</h3>
    <p>No venue requests have been submitted yet.</p>
  </div>
<% end %>
