<h1>Dashboard</h1>

<p>Welcome, <%= current_user.email %></p>

<p>Role: <strong><%= current_user.role.humanize.titleize %></strong></p>

<% if current_user.admin? %>
  <p>You have <strong>Admin</strong> privileges.</p>
  <p><%= link_to "Admin Panel", admin_path %></p>
  <p><%= link_to "Approval Dashboard", approval_dashboard_path %></p>
  <p><%= link_to "Analytics Dashboard", analytics_path %></p>
<% elsif current_user.staff? %>
  <p>You are logged in as <strong>Staff</strong>.</p>
  <p><%= link_to "Approval Dashboard", approval_dashboard_path %></p>
  <p><%= link_to "Analytics Dashboard", analytics_path %></p>
<% else %>
  <p>You are a <strong>Society Member</strong>.</p>
<% end %>

<p><%= link_to "View Equipment", equipments_path %></p>
<p><%= link_to "View Venue", venues_path %></p>

<% unless current_user.society_member? %>
  <p><%= link_to "Booking", bookings_path %></p>
<% end %>
<% if current_user.society_member? %>
  <p><%= link_to "My Bookings", my_bookings_path %></p>
<% end %>

<%= button_to "Log out", logout_path, method: :delete %>
