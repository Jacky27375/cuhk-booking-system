<% content_for(:page_title, "Dashboard") %>

<p class="text-muted mb-2">Welcome back, <strong><%= current_user.email %></strong> &mdash; <span class="badge badge-role"><%= current_user.role.humanize.titleize %></span></p>

<div class="dashboard-grid">
  <% if current_user.student? %>
    <div class="dash-card">
      <div class="dash-icon">&#128203;</div>
      <h3>My Bookings</h3>
      <p>View and manage your venue and equipment bookings</p>
      <%= link_to "View Bookings &rarr;".html_safe, my_bookings_path %>
    </div>
  <% end %>

  <div class="dash-card">
    <div class="dash-icon">&#127963;</div>
    <h3>Venues</h3>
    <p>Browse available venues and make a reservation</p>
    <%= link_to "Browse Venues &rarr;".html_safe, venues_path %>
  </div>

  <div class="dash-card">
    <div class="dash-icon">&#128295;</div>
    <h3>Equipment</h3>
    <p>View and borrow equipment for your events</p>
    <%= link_to "View Equipment &rarr;".html_safe, equipments_path %>
  </div>

  <% unless current_user.student? %>
    <div class="dash-card">
      <div class="dash-icon">&#128197;</div>
      <h3>All Bookings</h3>
      <p>View all venue and equipment bookings</p>
      <%= link_to "View All &rarr;".html_safe, bookings_path %>
    </div>

    <div class="dash-card">
      <div class="dash-icon">&#9989;</div>
      <h3>Approvals</h3>
      <p>Review and approve pending booking requests</p>
      <%= link_to "Approval Dashboard &rarr;".html_safe, approval_dashboard_path %>
    </div>
  <% end %>

  <% if current_user.admin? || current_user.staff? %>
    <div class="dash-card">
      <div class="dash-icon">&#128202;</div>
      <h3>Analytics</h3>
      <p>Booking trends, usage statistics, and insights</p>
      <%= link_to "View Analytics &rarr;".html_safe, analytics_path %>
    </div>
  <% end %>

  <% if current_user.admin? %>
    <div class="dash-card">
      <div class="dash-icon">&#9881;&#65039;</div>
      <h3>Admin Panel</h3>
      <p>System administration and settings</p>
      <%= link_to "Open Admin &rarr;".html_safe, admin_path %>
    </div>
  <% end %>
</div>
