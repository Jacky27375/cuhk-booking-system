<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <h1>Create Account</h1>
      <p>Join the CUHK Booking System</p>
    </div>

    <% if @user.errors.any? %>
      <div class="alert">
        <ul style="margin:0; padding-left:1.2rem;">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: signup_path, method: :post, data: { turbo: false } do |f| %>
      <div class="form-group">
        <%= f.label :email, "CUHK Email" %>
        <%= f.email_field :email, required: true, autofocus: true,
            placeholder: "yourname@link.cuhk.edu.hk" %>
      </div>

      <div class="form-group">
        <%= f.label :password %>
        <%= f.password_field :password, required: true, placeholder: "Create a password" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm Password" %>
        <%= f.password_field :password_confirmation, required: true, placeholder: "Confirm your password" %>
      </div>

      <div class="form-group">
        <%= f.label :tenant_id, "College" %>
        <%= f.collection_select :tenant_id, @tenants, :id, :name,
            { prompt: "Select your college" }, { required: true } %>
      </div>

      <div>
        <%= f.submit "Send Verification Code", class: "btn-primary" %>
      </div>
    <% end %>

    <div class="auth-footer">
      Already have an account? <%= link_to "Sign in", login_path %>
    </div>
  </div>
</div>
