<h1>Sign up</h1>

<% if @user.errors.any? %>
  <div class="alert">
    <ul>
      <% @user.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @user, url: signup_path, method: :post, data: { turbo: false } do |f| %>
  <div>
    <%= f.label :email, "CUHK Email" %>
    <%= f.email_field :email, required: true, autofocus: true,
        placeholder: "yourname@link.cuhk.edu.hk" %>
  </div>

  <div>
    <%= f.label :password %>
    <%= f.password_field :password, required: true %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirm Password" %>
    <%= f.password_field :password_confirmation, required: true %>
  </div>

  <div>
    <p>New accounts are created with Student access by default.</p>
  </div>

  <div>
    <%= f.label :tenant_id, "College" %>
    <%= f.collection_select :tenant_id, @tenants, :id, :name,
        { prompt: "Select your college" }, { required: true } %>
  </div>

  <div>
    <%= f.submit "Sign up" %>
  </div>
<% end %>

<p>Already have an account? <%= link_to "Log in", login_path %></p>
