<%= form_with(model: venue) do |form| %>
  <% if venue.errors.any? %>
    <div class="alert mb-2">
      <strong><%= pluralize(venue.errors.count, "error") %> prohibited this venue from being saved:</strong>
      <ul style="margin:0.5rem 0 0; padding-left:1.2rem;">
        <% venue.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :name %>
    <%= form.text_field :name, placeholder: "Enter venue name" %>
  </div>

  <div class="form-group">
    <%= form.label :description %>
    <%= form.textarea :description, placeholder: "Describe this venue" %>
  </div>

  <div class="form-group">
    <%= form.label :department %>
    <%= form.select :department, @departments || [], { selected: venue.department.presence || (@departments&.first) } %>
  </div>

  <div>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
