<%= form_with(model: venue) do |form| %>
  <% if venue.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(venue.errors.count, "error") %> prohibited this venue from being saved:</h2>

      <ul>
        <% venue.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :description, style: "display: block" %>
    <%= form.textarea :description %>
  </div>

  <% departments = ["University", "Chung Chi College", "New Asia College", "United College", "Shaw College", "Morningside College", "S.H. Ho College", "CW Chu College", "Wu Yee Sun College", "Lee Woo Sing College"] %>
  <div>
    <%= form.label :department, style: "display: block" %>
    <%= form.select :department, departments, { selected: venue.department.presence || "University" } %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
