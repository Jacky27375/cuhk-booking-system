<h1>Equipment</h1>

<% if current_user.admin? || current_user.staff? %>
  <p><%= link_to "New Equipment", new_equipment_path %></p>
<% end %>

<% if @equipments.any? %>
  <table id="equipments-table" class="resource-grid-table">
    <thead>
      <tr>
        <th><%= sortable_header_link("Name", "name", current_sort: @sort_column, current_direction: @sort_direction) %></th>
        <th><%= sortable_header_link("Total Quantity", "quantity", current_sort: @sort_column, current_direction: @sort_direction) %></th>
        <th><%= sortable_header_link("Available Quantity", "available_quantity", current_sort: @sort_column, current_direction: @sort_direction) %></th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @equipments.each do |equipment| %>
        <tr>
          <td><%= equipment.name %></td>
          <td><%= equipment.quantity %></td>
          <td>available: <%= equipment.available_quantity %></td>
          <td>
            <%= link_to "View", equipment_path(equipment) %>
            | <%= link_to "Borrow", borrow_form_equipment_path(equipment) %>
            <% if current_user.admin? || current_user.staff? %>
              | <%= link_to "Edit", edit_equipment_path(equipment) %>
              | <%= button_to "Delete", equipment_path(equipment), method: :delete, form: { style: "display:inline" }, data: { turbo_confirm: "Delete this equipment?" } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No equipment found.</p>
<% end %>

<p><%= link_to "Back to Dashboard", dashboard_path %></p>
