<h1>Borrow <%= @equipment.name %></h1>

<p><strong>Available:</strong> <%= @equipment.available_quantity %> / <%= @equipment.quantity %></p>

<%= form_with model: @booking, url: borrow_equipment_path(@equipment), data: { turbo: false } do |f| %>
  <% if @booking.errors.any? %>
    <div class="alert">
      <ul>
        <% @booking.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :quantity %>
    <%= f.number_field :quantity, min: 1, required: true %>
  </div>

  <div>
    <%= f.label :start_date, "Start date" %>
    <%= f.date_field :start_date, required: true %>
  </div>

  <div>
    <%= f.label :end_date, "End date" %>
    <%= f.date_field :end_date, required: true %>
  </div>

  <%= f.submit "Borrow" %>
<% end %>

<p><%= link_to "Back to Equipment", equipments_path %></p>
