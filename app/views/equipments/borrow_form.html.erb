<% content_for(:page_title, "Borrow #{@equipment.name}") %>

<div class="card" style="max-width:500px;">
  <div class="card-header">
    <h3>Borrow <%= @equipment.name %></h3>
    <span class="badge badge-approved"><%= @equipment.available_quantity %> / <%= @equipment.quantity %> available</span>
  </div>
  <div class="card-body">
    <%= form_with model: @booking, url: borrow_equipment_path(@equipment), data: { turbo: false } do |f| %>
      <% if @booking.errors.any? %>
        <div class="alert mb-2">
          <ul style="margin:0; padding-left:1.2rem;">
            <% @booking.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.label :quantity %>
        <%= f.number_field :quantity, min: 1, required: true %>
      </div>

      <div class="form-group">
        <%= f.label :start_date, "Start Date" %>
        <%= f.date_field :start_date, required: true %>
      </div>

      <div class="form-group">
        <%= f.label :end_date, "End Date" %>
        <%= f.date_field :end_date, required: true %>
      </div>

      <%= f.submit "Borrow", class: "btn btn-primary" %>
    <% end %>
  </div>
  <div class="card-footer">
    <%= link_to "Back to Equipment", equipments_path, class: "btn btn-secondary btn-sm" %>
  </div>
</div>
