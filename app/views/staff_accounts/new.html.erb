<% content_for :title, "New Staff Account" %>
<% content_for(:page_title, "New Staff Account") %>

<div class="card">
  <div class="card-body">
    <p class="text-muted mb-2">Creating staff account for <strong><%= current_user.tenant.name %></strong></p>

    <% if @user.errors.any? %>
      <div class="alert">
        <ul style="margin:0; padding-left:1.2rem;">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: staff_accounts_path, method: :post do |f| %>
      <div class="form-group">
        <%= f.label :email, "CUHK Email" %>
        <%= f.email_field :email, required: true, autofocus: true,
            placeholder: "staffname@link.cuhk.edu.hk" %>
      </div>

      <div class="form-group">
        <%= f.label :password %>
        <%= f.password_field :password, required: true, placeholder: "Set a password" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm Password" %>
        <%= f.password_field :password_confirmation, required: true, placeholder: "Confirm password" %>
      </div>

      <div class="btn-group">
        <%= f.submit "Create Staff Account", class: "btn-primary" %>
        <%= link_to "Cancel", staff_accounts_path, class: "btn btn-secondary btn-sm" %>
      </div>
    <% end %>
  </div>
</div>
